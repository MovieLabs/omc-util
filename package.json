{
  "name": "omc-util",
  "version": "1.0.0",
  "description": "Utilities for working with OMC-JSON",
  "author": "DML",
  "license": "ISC",
  "main": "./index.mjs",
  "types": "./types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./index.mjs",
      "default": "./index.mjs"
    },
    "./compare": {
      "types": "./types/src/omc/omcCompare.d.ts",
      "import": "./src/omc/omcCompare.mjs"
    },
    "./edges": {
      "types": "./types/src/omc/omcEdges.d.ts",
      "import": "./src/omc/omcEdges.mjs"
    },
    "./find": {
      "types": "./types/src/omc/omcFind.d.ts",
      "import": "./src/omc/omcFind.mjs"
    },
    "./migrate": {
      "types": "./types/src/omc/migration/omcMigrate.d.ts",
      "import": "./src/omc/migration/omcMigrate.mjs"
    },
    "./graphql": {
      "types": "./types/src/omc/omcGraphQl/index.d.ts",
      "import": "./src/omc/omcGraphQl/index.mjs"
    },
    "./identifier": {
      "types": "./types/src/omc/omcIdentifier.d.ts",
      "import": "./src/omc/omcIdentifier.mjs"
    },
    "./transform": {
      "types": "./types/src/omc/omcTransform.d.ts",
      "import": "./src/omc/omcTransform.mjs"
    },
    "./validate": {
      "types": "./types/src/omc/validation/omcValidate.d.ts",
      "import": "./src/omc/validation/omcValidate.mjs"
    },
    "./sdk": {
      "types": "./types/src/omcModel/omcSDK.d.ts",
      "import": "./src/omcModel/omcSDK.mjs"
    },
    "./config": {
      "types": "./types/src/config/index.d.ts",
      "import": "./src/config/index.mjs"
    },
    "./entity-model": {
      "types": "./types/src/omcModel/entityModel.d.ts",
      "import": "./src/omcModel/entityModel.mjs"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "jsdoc": "jsdoc -a all -c jsdoc.json -r -R README.md index.mjs -d docs/jsdoc --verbose",
    "build:types": "tsc && node postbuild-types.mjs"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@stylistic/eslint-plugin": "^5.8.0",
    "docdash": "^2.0.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.0.0",
    "jsdoc": "^4.0.3",
    "jsdoc-to-markdown": "^9.0.2",
    "typescript": "^6.0.2"
  }
}
